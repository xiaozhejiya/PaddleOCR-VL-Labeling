# =========================
# 应用基础配置
# =========================
# 运行环境：dev / test / prod
APP_ENV=dev
# 应用名称（用于日志、监控标识）
APP_NAME=document-annotation-platform
# API 统一前缀
API_PREFIX=/api/v1

# =========================
# 数据库与缓存队列配置
# =========================
# PostgreSQL 连接串（必须替换占位符，不可直接使用默认值）
DATABASE_URL=postgresql+psycopg://annotation_app:<REPLACE_WITH_STRONG_DB_PASSWORD>@127.0.0.1:5432/annotation_platform
# Alembic / DDL 迁移连接串（仅执行 migration 时临时设置；不要给 FastAPI/Celery 使用）
MIGRATOR_DATABASE_URL=postgresql+psycopg://annotation_migrator:<REPLACE_WITH_STRONG_MIGRATOR_PASSWORD>@127.0.0.1:5432/annotation_platform
# Redis 连接（缓存；必须替换占位符）
REDIS_URL=redis://:<REPLACE_WITH_STRONG_REDIS_PASSWORD>@127.0.0.1:6379/0
# Celery 消息队列（Broker；必须替换占位符）
CELERY_BROKER_URL=redis://:<REPLACE_WITH_STRONG_REDIS_PASSWORD>@127.0.0.1:6379/1
# Celery 任务结果存储（Backend；必须替换占位符）
CELERY_RESULT_BACKEND=redis://:<REPLACE_WITH_STRONG_REDIS_PASSWORD>@127.0.0.1:6379/2

# =========================
# 文件存储配置
# =========================
# 本地受控存储根目录（原始文件、revision、导出包等）
STORAGE_ROOT=./data
# 上传大小上限（MB）
MAX_UPLOAD_MB=200

# =========================
# 鉴权配置
# =========================
# JWT 签名密钥：必须替换为强随机密钥，不可提交真实值
JWT_SECRET_KEY=<REPLACE_WITH_STRONG_JWT_SECRET>
# JWT 过期时间（分钟）
JWT_EXPIRE_MINUTES=1440

# =========================
# 种子管理员配置（alembic upgrade head 时自动创建）
# =========================
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=<REPLACE_WITH_ADMIN_PASSWORD>

# =========================
# PaddleOCR-VL 配置
# =========================
# 是否启用 PaddleOCR-VL 预标注能力（true / false）。
# 具体模型名称、模型目录或远程服务地址由每次 run_config 记录，不放在全局 .env。
PADDLEOCR_VL_ENABLED=false
